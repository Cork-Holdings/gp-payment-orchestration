{
  "info": {
    "_postman_id": "gp-payment-orchestration-2024",
    "name": "GP Payment Orchestration API",
    "description": "Payment orchestration platform API with OAuth, merchant endpoints, and admin management.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080", "type": "string"},
    {"key": "client_id", "value": "", "type": "string"},
    {"key": "client_secret", "value": "", "type": "string"},
    {"key": "bearer_token", "value": "", "type": "string"}
  ],
  "item": [
    {
      "name": "Health & OAuth",
      "item": [
        {"name": "Health Check", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"]}}},
        {"name": "Generate OAuth Token", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}], "body": {"mode": "urlencoded", "urlencoded": [{"key": "client_id", "value": "{{client_id}}"}, {"key": "client_secret", "value": "{{client_secret}}"}]}, "url": {"raw": "{{baseUrl}}/oauth/token", "host": ["{{baseUrl}}"], "path": ["oauth", "token"]}}}
      ]
    },
    {
      "name": "Merchant API - Mobile Money",
      "item": [
        {"name": "Collect", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{bearer_token}}"}, {"key": "X-Client-ID", "value": "{{client_id}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"phone_number\": \"+256701234567\", \"amount\": 50000}"}, "url": {"raw": "{{baseUrl}}/api/v1/mobile-money/collect", "host": ["{{baseUrl}}"], "path": ["api", "v1", "mobile-money", "collect"]}}},
        {"name": "Disburse", "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{bearer_token}}"}, {"key": "X-Client-ID", "value": "{{client_id}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"phone_number\": \"+256701234567\", \"amount\": 50000, \"narration\": \"Payment\"}"}, "url": {"raw": "{{baseUrl}}/api/v1/mobile-money/disburse", "host": ["{{baseUrl}}"], "path": ["api", "v1", "mobile-money", "disburse"]}}},
        {"name": "Check Collection Status", "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{bearer_token}}"}, {"key": "X-Client-ID", "value": "{{client_id}}"}], "url": {"raw": "{{baseUrl}}/api/v1/mobile-money/check-status/:transaction_ref", "host": ["{{baseUrl}}"], "path": ["api", "v1", "mobile-money", "check-status", ":transaction_ref"], "variable": [{"key": "transaction_ref", "value": ""}]}}},
        {"name": "Check Collection Balance", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/mobile-money/collect/balance", "host": ["{{baseUrl}}"], "path": ["api", "v1", "mobile-money", "collect", "balance"]}}},
        {"name": "Check Disbursement Status", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/mobile-money/disburse/status/:transaction_ref", "host": ["{{baseUrl}}"], "path": ["api", "v1", "mobile-money", "disburse", "status", ":transaction_ref"], "variable": [{"key": "transaction_ref", "value": ""}]}}},
        {"name": "Check Disbursement Balance", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/api/v1/mobile-money/disburse/balance", "host": ["{{baseUrl}}"], "path": ["api", "v1", "mobile-money", "disburse", "balance"]}}}
      ]
    },
    {
      "name": "Admin - Fee Profiles",
      "item": [
        {"name": "Create", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Standard Fee Profile\"}"}, "url": {"raw": "{{baseUrl}}/fee-profiles/create", "host": ["{{baseUrl}}"], "path": ["fee-profiles", "create"]}}},
        {"name": "List", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/fee-profiles/list", "host": ["{{baseUrl}}"], "path": ["fee-profiles", "list"]}}},
        {"name": "Get", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/fee-profiles/get/:id", "host": ["{{baseUrl}}"], "path": ["fee-profiles", "get", ":id"], "variable": [{"key": "id", "value": ""}]}}},
        {"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"id\": \"\", \"name\": \"Updated Fee Profile\"}"}, "url": {"raw": "{{baseUrl}}/fee-profiles/update", "host": ["{{baseUrl}}"], "path": ["fee-profiles", "update"]}}},
        {"name": "Delete", "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/fee-profiles/delete/:id", "host": ["{{baseUrl}}"], "path": ["fee-profiles", "delete", ":id"], "variable": [{"key": "id", "value": ""}]}}}
      ]
    },
    {
      "name": "Admin - Payment Services",
      "item": [
        {"name": "Create", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Mobile Money\", \"code\": \"MM\"}"}, "url": {"raw": "{{baseUrl}}/payment-services/create", "host": ["{{baseUrl}}"], "path": ["payment-services", "create"]}}},
        {"name": "List", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/payment-services/list", "host": ["{{baseUrl}}"], "path": ["payment-services", "list"]}}},
        {"name": "Get", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/payment-services/get/:id", "host": ["{{baseUrl}}"], "path": ["payment-services", "get", ":id"], "variable": [{"key": "id", "value": ""}]}}},
        {"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "url": {"raw": "{{baseUrl}}/payment-services/update", "host": ["{{baseUrl}}"], "path": ["payment-services", "update"]}}},
        {"name": "Delete", "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/payment-services/delete/:id", "host": ["{{baseUrl}}"], "path": ["payment-services", "delete", ":id"], "variable": [{"key": "id", "value": ""}]}}}
      ]
    },
    {
      "name": "Admin - Payment Channels",
      "item": [
        {"name": "Create", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"MTN UG\", \"code\": \"MTN_UG\"}"}, "url": {"raw": "{{baseUrl}}/payment-channels/create", "host": ["{{baseUrl}}"], "path": ["payment-channels", "create"]}}},
        {"name": "List", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/payment-channels/list", "host": ["{{baseUrl}}"], "path": ["payment-channels", "list"]}}},
        {"name": "Get", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/payment-channels/get/:id", "host": ["{{baseUrl}}"], "path": ["payment-channels", "get", ":id"], "variable": [{"key": "id", "value": ""}]}}},
        {"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "url": {"raw": "{{baseUrl}}/payment-channels/update", "host": ["{{baseUrl}}"], "path": ["payment-channels", "update"]}}},
        {"name": "Delete", "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/payment-channels/delete/:id", "host": ["{{baseUrl}}"], "path": ["payment-channels", "delete", ":id"], "variable": [{"key": "id", "value": ""}]}}}
      ]
    },
    {
      "name": "Admin - Transaction Types",
      "item": [
        {"name": "Create", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Collection\", \"code\": \"COLLECTION\"}"}, "url": {"raw": "{{baseUrl}}/transaction-types/create", "host": ["{{baseUrl}}"], "path": ["transaction-types", "create"]}}},
        {"name": "List", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/transaction-types/list", "host": ["{{baseUrl}}"], "path": ["transaction-types", "list"]}}},
        {"name": "Get", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/transaction-types/get/:id", "host": ["{{baseUrl}}"], "path": ["transaction-types", "get", ":id"], "variable": [{"key": "id", "value": ""}]}}},
        {"name": "Update", "request": {"method": "PUT", "header": [{"key": "Content-Type", "value": "application/json"}], "url": {"raw": "{{baseUrl}}/transaction-types/update", "host": ["{{baseUrl}}"], "path": ["transaction-types", "update"]}}},
        {"name": "Delete", "request": {"method": "DELETE", "url": {"raw": "{{baseUrl}}/transaction-types/delete/:id", "host": ["{{baseUrl}}"], "path": ["transaction-types", "delete", ":id"], "variable": [{"key": "id", "value": ""}]}}}
      ]
    },
    {
      "name": "Admin - Merchant Management",
      "item": [
        {"name": "Create Merchant Fee Profile", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"merchant_id\": \"\", \"fee_profile_id\": \"\"}"}, "url": {"raw": "{{baseUrl}}/merchant-fee-profiles/create", "host": ["{{baseUrl}}"], "path": ["merchant-fee-profiles", "create"]}}},
        {"name": "List Merchant Fee Profiles", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/merchant-fee-profiles/list", "host": ["{{baseUrl}}"], "path": ["merchant-fee-profiles", "list"]}}},
        {"name": "Create Merchant API Key", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"merchant_id\": \"\", \"name\": \"API Key 1\"}"}, "url": {"raw": "{{baseUrl}}/merchant-api-keys/create", "host": ["{{baseUrl}}"], "path": ["merchant-api-keys", "create"]}}},
        {"name": "List Merchant API Keys", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/merchant-api-keys/list", "host": ["{{baseUrl}}"], "path": ["merchant-api-keys", "list"]}}},
        {"name": "Add Merchant IP", "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"merchant_id\": \"\", \"ip_address\": \"192.168.1.1\"}"}, "url": {"raw": "{{baseUrl}}/merchant-ips/add", "host": ["{{baseUrl}}"], "path": ["merchant-ips", "add"]}}},
        {"name": "List Merchant IPs", "request": {"method": "GET", "url": {"raw": "{{baseUrl}}/merchant-ips/list", "host": ["{{baseUrl}}"], "path": ["merchant-ips", "list"]}}}
      ]
    }
  ]
}