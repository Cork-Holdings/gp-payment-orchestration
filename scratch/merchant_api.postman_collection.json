{
	"info": {
		"_postman_id": "4b684803-b1d6-4447-9293-f14d8c6b9944",
		"name": "GeePay Merchant API",
		"description": "GeePay Merchant API Collection including OAuth 2.0 Client Credentials flow, Mobile Money Collections, and Disbursements with automated signature generation.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. OAuth Token Generation",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.access_token) {",
							"    pm.collectionVariables.set(\"token\", jsonData.access_token);",
							"    console.log(\"Saved JWT access token to collection variables.\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{
							"key": "client_id",
							"value": "{{client_id}}",
							"type": "text"
						},
						{
							"key": "client_secret",
							"value": "{{client_secret}}",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/oauth/token",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"oauth",
						"token"
					]
				},
				"description": "Generate an access token using Client ID and Client Secret. The token is automatically saved into the collection variable `token` for subsequent requests."
			},
			"response": []
		},
		{
			"name": "2. Mobile Money Collect (Async)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "X-Client-ID",
						"value": "{{client_id}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"phone_number\": \"260971234567\",\n    \"amount\": 150.00,\n    \"currency\": \"USD\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/v1/mobile-money/collect",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"mobile-money",
						"collect"
					]
				},
				"description": "Submit a collection request. Responds with HTTP 202 Accepted. The phone number must be exactly 12 digits."
			},
			"response": []
		},
		{
			"name": "3. Mobile Money Disburse (Sync)",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Automatically compute HMAC-SHA256 signature from raw body and client secret",
							"var requestBody = pm.request.body.raw;",
							"var secret = pm.collectionVariables.get(\"client_secret\");",
							"if (!secret) {",
							"    secret = \"secret_456\";",
							"}",
							"var hash = CryptoJS.HmacSHA256(requestBody, secret);",
							"var signature = hash.toString(CryptoJS.enc.Hex);",
							"pm.request.headers.upsert({key: 'X-Auth-Signature', value: signature});",
							"console.log(\"Calculated and injected X-Auth-Signature: \" + signature);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{token}}",
						"type": "text"
					},
					{
						"key": "X-Client-ID",
						"value": "{{client_id}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\"phone_number\":\"260971234567\",\"amount\":150.00,\"currency\":\"USD\"}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/v1/mobile-money/disburse",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"v1",
						"mobile-money",
						"disburse"
					]
				},
				"description": "Synchronous disbursement request. Injects X-Auth-Signature automatically calculated via a pre-request script."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:2050",
			"type": "string"
		},
		{
			"key": "client_id",
			"value": "merchant_123",
			"type": "string"
		},
		{
			"key": "client_secret",
			"value": "secret_456",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	]
}
